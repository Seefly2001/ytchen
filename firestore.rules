rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      // Hardcoded Bootstrap Admin from user request metadata
      return isSignedIn() && isEmailVerified() && request.auth.token.email == "ytchen@mail.tncvs.tn.edu.tw";
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validations ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.price is number && data.price >= 0
          && data.category is string && data.category.size() > 0
          && data.isAvailable is bool;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 50;
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0
          && data.totalAmount is number && data.totalAmount >= 0
          && data.status in ['pending', 'preparing', 'completed', 'cancelled']
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // --- Rules ---

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Temporary for seeding/admin without auth
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true; // Temporary for seeding/admin without auth
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow read, update, delete: if true; // Allow all for management without auth
    }
  }
}
